---
const currentYear = new Date().getFullYear();

import { Image } from "astro:assets"
import caducee from '../assets/caducee.png';
---
<footer class="bg-footer-1 text-footer-text border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col md:flex-row justify-between items-center gap-8">
        <aside class="text-center md:text-left">
            <a href="/" class="flex items-center gap-3 group transition-transform active:scale-95">
                <div class="w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center">
                    <Image 
                        src={caducee} 
                        alt="Caducée infirmiers" 
                        width={36} 
                        height={36}
                        class="object-contain"
                        loading="lazy"
                    />
                </div>
                
                <div class="flex flex-col leading-tight">
                    <span class="text-2xl font-serif tracking-wide">Cabinet Infirmiers DELHERM</span>
                </div>
            </a>
            <!-- <p class="text-2xl font-serif font-semibold tracking-wide">
                🌸 Cabinet Infirmier DELHERM
            </p> -->
            <p class="text-sm opacity-60 italic mt-1">
                Soins infirmiers à Castanet-Tolosan
            </p>
        </aside>

        <nav class="flex gap-6">
            <a href="/mentions-legales" class="text-sm opacity-80 hover:opacity-100 hover:text-white transition-all">
                Mentions légales
            </a>
            <a href="/politique" class="text-sm opacity-80 hover:opacity-100 hover:text-white transition-all">
                Confidentialité
            </a>
        </nav>
    </div>

    <div class="bg-black/20 py-4 px-6">
        <div class="max-w-7xl mx-auto flex flex-col items-center justify-center gap-2 text-xs md:text-sm opacity-80">
            <aside class="flex flex-col sm:flex-row gap-2 sm:gap-4 items-center">
                <p>© {currentYear} Cabinet Delherm - Tous droits réservés.</p>
                <span class="hidden sm:inline opacity-50">|</span>
                <a href="mailto:oufrid31@outlook.fr" class="hover:text-white transition-colors duration-300">
                    Réalisation : <span class="font-bold text-white hover:text-white transition-colors duration-300">wilbou.dev</span>
                </a>
            </aside>
        </div>
    </div>
</footer>