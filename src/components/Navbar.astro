---
import { Image } from "astro:assets"
import caducee from '../assets/caducee.png';
---
<header class="sticky top-0 z-[100] px-4 py-3">
    <nav class="max-w-7xl mx-auto navbar bg-header-1 backdrop-blur-md border border-white/20 shadow-lg rounded-2xl px-4 transition-all duration-300">
        
        <!-- START : Logo & Burger -->
        <div class="navbar-start">
            <!-- Mobile Menu -->
            <div class="dropdown lg:hidden">
                <div tabindex="0" 
                    role="button" 
                    class="btn btn-ghost btn-circle text-button-1"
                    aria-label="Ouvrir le menu de navigation"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
                    </svg>
                    <span class="sr-only">Menu</span>
                </div>
                <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-xl bg-white rounded-2xl w-64 border border-slate-100 gap-2">
                    <li><a href="/" class="py-3 px-4 rounded-xl active:bg-button-1">Accueil</a></li>
                    <li><a href="/soins" class="py-3 px-4 rounded-xl">Les soins</a></li>
                    <li><a href="/aPropos" class="py-3 px-4 rounded-xl">À propos</a></li>
                    <li><a href="/contact" class="py-3 px-4 rounded-xl font-bold text-button-1">Contact</a></li>
                </ul>
            </div>

            <!-- Logo -->
            <a href="/" class="flex items-center gap-3 group transition-transform active:scale-95">
                <div class="w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center">
                    <Image 
                        src={caducee} 
                        alt="Caducée infirmiers" 
                        width={48} 
                        height={48}
                        class="object-contain"
                        loading="eager"
                    />
                </div>
                
                <div class="flex flex-col leading-tight">
                    <span class="font-serif text-slate-800 text-lg sm:text-xl">Cabinet</span>
                    <span class="font-sans font-black text-button-1 text-xs sm:text-sm tracking-widest uppercase">Delherm</span>
                </div>
            </a>
        </div>

        <!-- CENTER : Navigation Desktop -->
        <div class="navbar-center hidden lg:flex">
            <ul class="flex items-center gap-8 font-sans font-medium text-slate-600">
                <li>
                    <a href="/" class="hover:text-button-1 transition-colors relative after:content-[''] after:absolute after:w-0 after:h-0.5 after:bg-button-1 after:left-0 after:-bottom-1 hover:after:w-full after:transition-all">Accueil</a>
                </li>
                <li>
                    <a href="/soins" class="hover:text-button-1 transition-colors relative after:content-[''] after:absolute after:w-0 after:h-0.5 after:bg-button-1 after:left-0 after:-bottom-1 hover:after:w-full after:transition-all">Les soins</a>
                </li>
                <li>
                    <a href="/aPropos" class="hover:text-button-1 transition-colors relative after:content-[''] after:absolute after:w-0 after:h-0.5 after:bg-button-1 after:left-0 after:-bottom-1 hover:after:w-full after:transition-all">À propos</a>
                </li>
                <li>
                    <a href="/contact" class="hover:text-button-1 transition-colors relative after:content-[''] after:absolute after:w-0 after:h-0.5 after:bg-button-1 after:left-0 after:-bottom-1 hover:after:w-full after:transition-all">Contact</a>
                </li>
            </ul>
        </div>

        <!-- END : Bouton d'action -->
        <div class="navbar-end">
            <a href="tel:0669336538" class="btn bg-button-1 border-none text-white rounded-xl shadow-md hover:bg-button-hover-1 hover:shadow-button-1/20 transition-all group px-4 sm:px-6">
                <span class="hidden sm:inline group-hover:scale-110 transition-transform mr-1">📞</span>
                <span class="text-xs sm:text-sm font-bold uppercase tracking-tight">Appeler</span>
            </a>
        </div>
    </nav>
</header>