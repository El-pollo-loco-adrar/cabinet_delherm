---
import Layout from '../layouts/Layout.astro';
import CardSoin from '../components/CardSoin.astro';
import Badge from '../components/Badge.astro';


const soins = [
    {
        title: "Soins généraux",
        description: ["Pansements simples et complexes", "Injections (IM, SC, IV)", "Prises de sang", "Surveillance glycémie et insuline", "Retrait de points ou d'agrafes"],
        emoji:"💉",
        badge:"Soins généraux",
        badgeBg: "bg-emerald-100",
        badgeText: "text-emerald-800"
    },
    {
        title: "Maintien à domicile",
        description: ["Soins d'hygiène (nursing)", "Aide à l'habillage", "Pose de bas de contention", "Distribution et suivi des traitements", "Accompagnement dépendance"],
        emoji:"🕊️",
        badge: "Accompagnement",
        badgeBg: "bg-purple-100",
        badgeText: "text-purple-800"
    },
    {
        title: "Soins complexes",
        description: ["Perfusions", "Chimiothérapie à domicile", "Traitement des plaies chroniques", "Soins de stomie", "Accompagnement palliatif"],
        emoji:"💧",
        badge: "Spécialisé",
        badgeBg: "bg-rose-100",
        badgeText: "text-rose-800"
    },
    {
        title: "Consultation et suivi",
        description: ["Consultation infirmière", "Suivi vaccinal", "Éducation thérapeutique", "Prévention des risques de chute"],
        emoji:"📚",
        badge: "Prévention",
        badgeBg: "bg-amber-100",
        badgeText: "text-amber-800"
    }
];
---

<Layout 
	title ="Nos Soins Infirmiers | Cabinet Delherm Castanet-Tolosan"
	description ="Soins généraux (pansements, injections), retrait agrafes et points, toilettes, maintien à domicile, soins palliatifs et suivi diabétique à Castanet-Tolosan. Erika Ramade et Mathieu Bourrinet interviennent 7j/7."
>
	<section class="relative overflow-hidden bg-header-1 pt-8 pb-8 lg:pt-16 lg:pb-16">
		<div class="container mx-auto px-4">
		
		<!-- Titre de la page -->
		<div class="text-center mb-16">
			<Badge text="Cabinet d'infirmiers à domicile · Castanet-Tolosan"/>
			<h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-tight mb-6">Nos Soins 
				<span class="text-button-1">Infirmiers</span> 
			</h1>
			<p class="font-sans text-lg text-slate-600 mb-10 max-w-2xl mx-auto">
			Erika Ramade et Mathieu Bourrinet assurent une prise en charge complète sur prescription médicale, <strong>7 jours sur 7</strong>, pour les patients de tous âges.
			</p>
		</div>

		<!-- C'EST ICI QUE TU METS LA GRILLE -->
		<div class="flex flex-wrap justify-center gap-8 max-w-7xl mx-auto">
    {soins.map((soin) => (
        <div class="w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] max-w-md bg-white p-8 rounded-3xl shadow-sm border border-slate-100 flex flex-col hover:shadow-md transition-shadow">
            
            <!-- Header de la Card -->
            <div class="flex items-start justify-between mb-6">
                <span class={`text-4xl p-3 rounded-2xl ${soin.badgeBg}`}>
                    {soin.emoji}
                </span>
                <span class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest ${soin.badgeBg} ${soin.badgeText}`}>
                    {soin.badge}
                </span>
            </div>

            <h2 class="text-2xl font-serif text-slate-900 mb-4">{soin.title}</h2>

            <!-- La Liste à puces -->
            <ul class="space-y-3 flex-1">
                {soin.description.map((item) => (
                    <li class="flex items-start gap-3 text-slate-600 text-sm leading-tight">
                        <span class={`mt-1.5 w-1.5 h-1.5 rounded-full shrink-0 ${soin.badgeBg.replace('100', '400')}`}></span>
                        {item}
                    </li>
                ))}
            </ul>
        </div>
    ))}
</div>

		<!-- Section supplémentaire pour le SEO Local -->
        <div class="mt-20 max-w-3xl mx-auto text-center border-t border-slate-200 pt-10">
            <h2 class="text-2xl font-serif text-slate-800 mb-4">Zone d'intervention à Castanet-Tolosan</h2>
            <p class="text-slate-600 leading-relaxed">
                Votre cabinet d'infirmiers se déplace pour vos soins à domicile sur la commune de <strong>Castanet-Tolosan</strong> et les secteurs limitrophes. Nous travaillons en étroite collaboration avec les laboratoires et médecins du secteur pour garantir la continuité de vos soins.
            </p>
        </div>
		
		<!-- Petit rappel après les cartes -->
		<div class="mt-16 text-center">
			<p class="text-sm mb-8 text-slate-500 italic">
			* Pour tout autre soin, n'hésitez pas à nous contacter directement par téléphone.
			</p>
			<a href="tel:0669336538" class="btn btn-lg btn-ghost rounded-full border-slate-300 hover:bg-slate-100 text-slate-700">
				📞 06 69 33 65 38
			</a>
		</div>

		</div>
	</section>
</Layout>
