---
import Layout from '../layouts/Layout.astro';
import CardSoin from '../components/CardSoin.astro';

const soins = [
	{
		title: "Soins Courants",
		description: "Injections et prélèvements quotidiens.",
		details: ["Injections (SC, IM, IV)", "Prises de sang", "Vaccinations", "Tests PCR / Antigéniques"],
		badge: "Sur RDV"
	},
	{
		title: "Pansements",
		description: "Gestion de la cicatrisation.",
		details: ["Pansements simples", "Pansements complexes", "Retrait de fils/agrafes", "Ulcères et escarres"],
		badge: "Fréquent"
	},
	{
		title: "Diabétologie",
		description: "Accompagnement et suivi.",
		details: ["Surveillance glycémie", "Injection insuline", "Éducation thérapeutique", "Soins des pieds"],
		badge: "Sur RDV"
	},
	{
		title: "Perfusion",
		description: "Administration de traitements.",
		details: ["Pose de perfusion", "Changement de flacon", "Entretien de cathéter", "Nutrition parentérale"],
		badge: "Trop cher"
	},
	{
		title: "Accompagnement",
		description: "Soins de confort et de vie.",
		details: ["Aide à la toilette", "Gestion pilulier", "Soins palliatifs", "Soutien psychologique"]
	}
];
---

<Layout 
	title ="Nos Soins - Cabinet DELHERM"
	description =""
>
	<section class="relative overflow-hidden bg-header-1 pt-8 pb-8 lg:pt-16 lg:pb-16">
		<div class="container mx-auto px-4">
		
		<!-- Titre de la page -->
		<div class="text-center mb-16">
			<span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold tracking-wide text-button-1 uppercase bg-red-50 rounded-full font-sans">
				Cabinet d'infirmiers libéral à domicile · Castanet-Tolosan
			</span>
			<h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-tight mb-6">Nos Soins 
				<span class="italic text-button-1">Infirmiers</span> 
			</h1>
			<p class="font-sans text-lg text-slate-600 mb-10 max-w-2xl mx-auto">
			Nous intervenons à domicile et au cabinet sur prescription médicale.
			</p>
		</div>

		<!-- C'EST ICI QUE TU METS LA GRILLE -->
		<div class="flex flex-wrap justify-center gap-8 max-w-6xl mx-auto">
			{soins.map((soin) => (
			<div class="w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] max-w-sm"> <!-- On limite la largeur max pour éviter que les cartes soient trop larges sur tablette -->
				<CardSoin {...soin} />
			</div>
			))}
		</div>

		<!-- Petit rappel après les cartes -->
		<div class="mt-16 text-center">
			<p class="text-sm mb-8 text-slate-500 italic">
			* Pour tout autre soin, n'hésitez pas à nous contacter directement par téléphone.
			</p>
			<a href="tel:0600000000" class="btn btn-lg btn-ghost rounded-full border-slate-300 hover:bg-slate-100 text-slate-700">
				📞 06 00 00 00 00
			</a>
		</div>

		</div>
	</section>
</Layout>
