---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import { Image } from 'astro:assets';

import index1 from '../assets/index1.jpg';
import index3 from '../assets/index3.jpg'
---

<Layout 
	title ="Cabinet Infirmier Delherm - Soins à domicile à Castanet-Tolosan"
	description ="Erika Ramade et Mathieu Bourrinet, infirmiers diplômés d'État à Castanet-Tolosan. Soins infirmiers à domicile et au cabinet 7j/7"
>
<section class="relative min-h-[70vh] flex items-center overflow-hidden">
    <!-- L'image de fond -->
    <div class="absolute inset-0">
        <Image
            src={index1}
            alt="Cabinet Infirmier Delherm"
            class="w-full h-full object-cover object-[center_right]" 
            loading="eager"
        />
    </div>
    
    <!-- LE SECRET : Un dégradé blanc vers transparent -->
    <!-- Sur mobile il couvre tout, sur desktop il s'efface vers la droite -->
    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent md:from-white/95 md:via-white/60 md:to-transparent"></div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-2xl"> <!-- On aligne le texte à gauche pour profiter du dégradé -->
            <Badge text="Soins à domicile · Castanet-Tolosan" />
            
            <h1 class="font-serif text-4xl md:text-6xl text-slate-900 leading-tight mb-6 mt-4">
                Des soins infirmiers <br />
                <span class="italic text-button-1 text-5xl md:text-7xl">à domicile</span>
            </h1>
            
            <p class="font-sans text-lg text-slate-700 mb-8 max-w-lg">
                Erika et Mathieu vous accompagnent au quotidien avec bienveillance. Disponibles 7j/7 pour tous vos soins sur prescription médicale.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/contact" class="btn btn-lg bg-button-1 text-white rounded-full border-none px-10 shadow-xl hover:scale-105 transition-transform">
                    📅 Prendre rendez-vous
                </a>
                <a href="tel:0669336538" class="btn btn-lg bg-white border-slate-200 text-slate-700 rounded-full hover:bg-slate-50">
                    📞 06 69 33 65 38
                </a>
            </div>
        </div>
    </div>
</section>
</Layout>
