---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
---

<Layout 
	title ="Contact et Plan | Cabinet Infirmier Delherm Castanet-Tolosan"
	description ="Prenez rendez-vous avec Erika Ramade et Mathieu Bourrinet au 06 69 33 65 38. Cabinet situé au Centre Médical Louis Delherm à Castanet-Tolosan. Formulaire de contact et itinéraire."
>
	<section class="relative overflow-hidden bg-header-1 pt-16 pb-8 lg:pt-16 lg:pb-4">
		<div class="container mx-auto px-4">

			<div class="flex-1 text-center z-10">
				<Badge text="Cabinet d'infirmiers à domicile · Castanet-Tolosan"/>
				<h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-tight mb-6">Contactez <span class="text-button-1">vos infirmiers</span>
				</h1>
				<p class="font-sans text-lg text-slate-600 mb-10 max-w-2xl mx-auto">Besoin de soins à domicile ou au cabinet ? Nous vous répondons très rapidement.</p>
			</div>
		</div>
    </section>

    <section class="max-w-7xl mx-auto py-4 px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
            
            <div class="flex flex-col gap-8">
                <div class="bg-base-200 p-8 rounded-box shadow-sm border border-base-300 space-y-6">
                    <h2 class="text-3xl font-serif text-button-1 italic">Nous trouver</h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                        <div class="flex items-center gap-4"> 
                            <div class="text-primary text-3xl bg-white p-3 rounded-full shadow-sm border border-base-300">📍</div> 
                            <div> 
                                <p class="font-bold text-slate-900">Adresse</p> 
                                <p class="text-sm opacity-80 leading-relaxed">
                                    Centre médical Louis Delherm<br>
                                    17 avenue de la République,<br>
                                    31320 Castanet-Tolosan 
                                </p> 
                            </div> 
                        </div>

                        <div class="flex items-center gap-4"> 
                            <div class="text-primary text-3xl bg-white p-3 rounded-full shadow-sm border border-base-300">📞</div> 
                            <div> 
                                <p class="font-bold text-slate-900">Téléphone</p> 
                                <a href="tel:0669336538" class="hover:text-button-1 transition-colors"> 
                                    <p class="text-sm opacity-80 leading-relaxed font-semibold"> 
                                        06 69 33 65 38 
                                    </p> 
                                </a> 
                            </div> 
                        </div>
                    </div>

                    <div class="pt-4 border-t border-base-300 text-sm text-slate-600">
                        <p>🚗 <strong>Accès :</strong> Parking gratuit à proximité du centre médical.</p>
                        <p>🚌 <strong>Bus :</strong> Ligne L6, arrêt "République".</p>
                    </div>
                </div>

                <div class="flex-grow min-h-[400px] rounded-box shadow-lg overflow-hidden border-4 border-white relative z-10" id="map">
                    </div>
            </div>

            <div class="bg-white p-8 md:p-12 rounded-box shadow-xl border border-base-200 flex flex-col">
                <h2 class="text-3xl font-serif text-button-1 mb-2 italic">Écrivez-nous</h2>
                <p class="text-sm text-neutral/60 mb-8 font-medium tracking-wide uppercase">Une question ? Un rendez-vous particulier ?</p>
                
                <form
                    id="contact-form"
                    class="space-y-5"
                    name="contact-infirmiers"
                    action="https://formspree.io/f/xwvyqjao"
                    method="POST"
                >
                    <div class="form-control">
                        <label class="label"><span class="label-text font-bold">Objet de votre demande</span></label>
                        <select name="objet" class="select select-bordered focus:border-primary w-full bg-base-100" required>
                            <option disabled selected value="">Choisissez une option...</option>
                            <option value="devis"> Demande de RDV soins généraux</option>
                            <option value="information">Demande de prise en charge accompagnement quotidien</option>
                            <option value="autre">Autre...</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="form-control">
                            <label class="label"><span class="label-text font-bold">Nom</span></label>
                            <input name="nom" type="text" placeholder="Ex: Marie Dupont" class="input input-bordered focus:border-primary w-full bg-base-100" required />
                        </div>
                        <div class="form-control">
                            <label class="label"><span class="label-text font-bold">Email</span></label>
                            <input name="email" type="email" placeholder="votre@email.com" class="input input-bordered focus:border-primary w-full bg-base-100" required />
                        </div>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-bold">Message</span></label>
                        <textarea name="message" class="textarea textarea-bordered h-40 focus:border-primary w-full bg-base-100" placeholder="Décrivez votre demande en quelques mots..." required></textarea>
                    </div>

                    <button type="submit" id="submit-btn" class="btn bg-button-1 btn-lg w-full shadow-md mt-4 group hover:bg-button-hover-1">
						<span class="text-white">
                        Envoyer le message
						</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 group-hover:translate-x-1 transition-transform text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                    </button>
                </form>
            </div>

        </div>

        <div id="toast" class="hidden fixed bottom-5 right-5 bg-success text-success-content px-6 py-4 rounded-xl shadow-2xl z-50 animate-bounce">
            ✅ Message envoyé avec succès !
        </div>
    </section>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script>
    //MAP AVEC LEAFLET
    async function initMap() {
        //importation de leaflet que quand on en a besoin
        const L = (await import('leaflet')).default;

        delete (L.Icon.Default.prototype as any)._getIconUrl;
        L.Icon.Default.mergeOptions({
            iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
            iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
            shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
        });

        const lat = 43.5160712945091;
        const lng = 1.5027044587561622;

        const map = L.map('map').setView([lat, lng], 15);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);
        const marker = L.marker([lat, lng]).addTo(map);
        marker.bindPopup("<b>Cabinet d'infirmiers</b><br>Centre médical Louis Delherm").openPopup();
    }

    //On charge la map que si elle est visible
    const mapElement = document.getElementById('map');
    if (mapElement) {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    initMap();
                    observer.disconnect();
                }
            });
        }, { rootMargin: "200px"}); // On commence à charger 200px avant qu'elle arrive à l'écran

        observer.observe(mapElement);
    }

    // FORMULAIRE
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const toast = document.getElementById('toast');
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;

    if(form && btn && toast) {
        const originalContent = btn.innerHTML;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            btn.disabled = true;
            btn.innerText = "Envoie en cours ...";

            const data = new FormData(form);

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: data,
                    headers: { 'Accept': 'application/json' }
                });

                if (response.ok) {
                    toast.classList.remove('hidden', 'translate-y-10');
                    form.reset();

                    setTimeout(() => {
                        toast.classList.add('hidden', 'translate-y-10');
                    }, 5000);

                }else {
                    alert("Oups ! Un problème est survenu. Veuillez réessayer.");
                }
            } catch (error) {
                alert("Erreur de connexion. Vérifiez votre réseau.");
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        })
    }
</script>
