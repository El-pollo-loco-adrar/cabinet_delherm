---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
---

<Layout 
	title =""
	description =""
>
	<section class="relative overflow-hidden bg-header-1 pt-16 pb-8 lg:pt-16 lg:pb-4">
		<div class="container mx-auto px-4">

			<div class="flex-1 text-center z-10">
				<Badge text="Cabinet d'infirmiers libéral à domicile · Castanet-Tolosan"/>
				<h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-slate-900 leading-tight mb-6">Contactez-<span class="text-button-1">nous</span>
				</h1>
				<p class="font-sans text-lg text-slate-600 mb-10 max-w-2xl mx-auto">Vous avez une question ? Un rendez-vous particulier ? N'hésitez pas à nous contacter !</p>
			</div>
			
		</div>
    </section>

    <section class="max-w-7xl mx-auto py-4 px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
            
            <div class="flex flex-col gap-8">
                <div class="bg-base-200 p-8 rounded-box shadow-sm border border-base-300 space-y-6">
                    <h1 class="text-3xl font-serif text-button-1 italic">Nous trouver</h1>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                        <div class="flex items-start gap-3">
                            <div class="text-primary text-2xl">📍</div>
                            <div>
                                <p class="font-bold">Adresse</p>
                                <p class="text-sm opacity-80 leading-relaxed">Centre médical Louis Delherm
                                    17 avenue de la République,<br>31320 Castanet-Tolosan
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3">
                            <div class="text-primary text-2xl">📞</div>
                            <div>
                                <p class="font-bold">Téléphone</p>
                                <a href="tel:0562170015">
                                    <p class="text-sm opacity-80 leading-relaxed">
                                    06 69 33 65 38
                                    </p>
                                </a>
                            </div>
                        </div>

                        
                    </div>
                </div>

                <div class="flex-grow min-h-[400px] rounded-box shadow-lg overflow-hidden border-4 border-white relative z-10" id="map">
                    </div>
            </div>

            <div class="bg-white p-8 md:p-12 rounded-box shadow-xl border border-base-200 flex flex-col">
                <h2 class="text-3xl font-serif text-button-1 mb-2 italic">Écrivez-nous</h2>
                <p class="text-sm text-neutral/60 mb-8 font-medium tracking-wide uppercase">Une question ? Un rendez-vous particulier ?</p>
                
                <form
                    id="contact-form"
                    class="space-y-5"
                    name="contact-elegance"
                    action="https://formspree.io/f/xpqkoavk"
                    method="POST"
                >
                    <div class="form-control">
                        <label class="label"><span class="label-text font-bold">Objet de votre demande</span></label>
                        <select name="objet" class="select select-bordered focus:border-primary w-full bg-base-100" required>
                            <option disabled selected value="">Choisissez une option...</option>
                            <option value="devis">Demande de devis</option>
                            <option value="information">Demande d'information</option>
                            <option value="lpg">Question LPG Endermologie</option>
                            <option value="autre">Autre...</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="form-control">
                            <label class="label"><span class="label-text font-bold">Nom</span></label>
                            <input name="nom" type="text" placeholder="Ex: Marie Dupont" class="input input-bordered focus:border-primary w-full bg-base-100" required />
                        </div>
                        <div class="form-control">
                            <label class="label"><span class="label-text font-bold">Email</span></label>
                            <input name="email" type="email" placeholder="votre@email.com" class="input input-bordered focus:border-primary w-full bg-base-100" required />
                        </div>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-bold">Message</span></label>
                        <textarea name="message" class="textarea textarea-bordered h-40 focus:border-primary w-full bg-base-100" placeholder="Décrivez votre demande en quelques mots..." required></textarea>
                    </div>

                    <button type="submit" id="submit-btn" class="btn bg-button-1 btn-lg w-full shadow-md mt-4 group hover:bg-button-hover-1">
						<span class="text-white">
                        Envoyer le message
						</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 group-hover:translate-x-1 transition-transform text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                    </button>
                </form>
            </div>

        </div>

        <div id="toast" class="hidden fixed bottom-5 right-5 bg-success text-success-content px-6 py-4 rounded-xl shadow-2xl z-50 animate-bounce">
            ✅ Message envoyé avec succès !
        </div>
    </section>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

